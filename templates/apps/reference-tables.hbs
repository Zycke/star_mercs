<div class="ref-tables-container">

  {{!-- Tab bar --}}
  <nav class="ref-tabs">
    <button class="ref-tab-btn {{#if (eq activeTab 'turn-structure')}}active{{/if}}" data-tab="turn-structure">Turn</button>
    <button class="ref-tab-btn {{#if (eq activeTab 'unit-traits')}}active{{/if}}" data-tab="unit-traits">Unit Traits</button>
    <button class="ref-tab-btn {{#if (eq activeTab 'weapon-traits')}}active{{/if}}" data-tab="weapon-traits">Weapon Traits</button>
    <button class="ref-tab-btn {{#if (eq activeTab 'orders')}}active{{/if}}" data-tab="orders">Orders</button>
    <button class="ref-tab-btn {{#if (eq activeTab 'terrain')}}active{{/if}}" data-tab="terrain">Terrain</button>
    <button class="ref-tab-btn {{#if (eq activeTab 'structures')}}active{{/if}}" data-tab="structures">Structures</button>
  </nav>

  {{!-- Turn Structure --}}
  {{#if (eq activeTab "turn-structure")}}
  <div class="ref-table-wrapper">
    <table class="ref-table turn-structure-table">
      <thead>
        <tr>
          <th class="col-flag">#</th>
          <th class="col-name">Phase</th>
          <th class="col-desc">Description</th>
        </tr>
      </thead>
      <tbody>
        {{#each turnStructure}}
        <tr class="phase-row">
          <td class="col-flag"><strong>{{order}}</strong></td>
          <td class="col-name"><strong><i class="{{icon}}"></i> {{phase}}</strong></td>
          <td class="col-desc">{{description}}</td>
        </tr>
        {{#each subPhases}}
        <tr class="sub-phase-row">
          <td class="col-flag"></td>
          <td class="col-name sub-phase-name">{{name}}</td>
          <td class="col-desc">{{description}}</td>
        </tr>
        {{/each}}
        {{/each}}
      </tbody>
    </table>
  </div>
  {{/if}}

  {{!-- Unit Traits Table --}}
  {{#if (eq activeTab "unit-traits")}}
  <div class="ref-table-wrapper">
    <table class="ref-table">
      <thead>
        <tr>
          <th class="col-name">Trait</th>
          <th class="col-type">Type</th>
          <th class="col-desc">Description</th>
        </tr>
      </thead>
      <tbody>
        {{#each unitTraits}}
        <tr>
          <td class="col-name"><strong>{{name}}</strong></td>
          <td class="col-type">{{type}}</td>
          <td class="col-desc">{{description}}</td>
        </tr>
        {{/each}}
      </tbody>
    </table>
  </div>
  {{/if}}

  {{!-- Weapon Traits Table --}}
  {{#if (eq activeTab "weapon-traits")}}
  <div class="ref-table-wrapper">
    <table class="ref-table">
      <thead>
        <tr>
          <th class="col-name">Trait</th>
          <th class="col-desc">Description</th>
        </tr>
      </thead>
      <tbody>
        {{#each weaponTraits}}
        <tr>
          <td class="col-name"><strong>{{name}}</strong></td>
          <td class="col-desc">{{description}}</td>
        </tr>
        {{/each}}
      </tbody>
    </table>
  </div>
  {{/if}}

  {{!-- Orders Table --}}
  {{#if (eq activeTab "orders")}}
  <div class="ref-table-wrapper">
    <table class="ref-table orders-table">
      <thead>
        <tr>
          <th class="col-name">Order</th>
          <th class="col-cat">Type</th>
          <th class="col-flag">Move</th>
          <th class="col-flag">Attack</th>
          <th class="col-flag">RDY</th>
          <th class="col-flag">Supply</th>
          <th class="col-desc">Description</th>
        </tr>
      </thead>
      <tbody>
        {{#each orders}}
        <tr>
          <td class="col-name"><strong>{{label}}</strong></td>
          <td class="col-cat">{{category}}</td>
          <td class="col-flag">{{move}}</td>
          <td class="col-flag">{{attack}}</td>
          <td class="col-flag">{{readiness}}</td>
          <td class="col-flag">{{supply}}</td>
          <td class="col-desc">{{description}}</td>
        </tr>
        {{/each}}
      </tbody>
    </table>
  </div>
  {{/if}}

  {{!-- Terrain Table --}}
  {{#if (eq activeTab "terrain")}}
  <div class="ref-table-wrapper">
    <h3>Terrain Types</h3>
    <table class="ref-table terrain-table">
      <thead>
        <tr>
          <th class="col-name">Terrain</th>
          <th class="col-flag">Move</th>
          <th class="col-flag">Sig Mod</th>
          <th class="col-flag">Inf. Cover</th>
          <th class="col-flag">Blocks LOS</th>
          <th class="col-flag">Water</th>
          <th class="col-flag">Veh. Impass.</th>
          <th class="col-flag">No Fort.</th>
        </tr>
      </thead>
      <tbody>
        {{#each terrainTypes}}
        <tr>
          <td class="col-name"><strong>{{label}}</strong></td>
          <td class="col-flag">{{movementCost}}</td>
          <td class="col-flag">{{signatureMod}}</td>
          <td class="col-flag">{{infantryCover}}</td>
          <td class="col-flag">{{blocksLOS}}</td>
          <td class="col-flag">{{waterTerrain}}</td>
          <td class="col-flag">{{impassableVehicle}}</td>
          <td class="col-flag">{{noFortification}}</td>
        </tr>
        {{/each}}
      </tbody>
    </table>

    <h3 style="margin-top: 1em;">Sight Point Cost by Elevation Difference</h3>
    <p class="hint">Each unit has a sight range (default 5 points). Each hex along the LOS path costs sight points based on how far below the observer it is. Hexes higher than the observer block LOS completely.</p>
    <table class="ref-table sight-table">
      <thead>
        <tr>
          <th class="col-flag">Elev. Diff.</th>
          <th class="col-flag">Cost / Hex</th>
        </tr>
      </thead>
      <tbody>
        {{#each sightTable}}
        <tr>
          <td class="col-flag">{{elevDiff}}</td>
          <td class="col-flag">{{cost}}</td>
        </tr>
        {{/each}}
      </tbody>
    </table>
  </div>
  {{/if}}

  {{!-- Structures Table --}}
  {{#if (eq activeTab "structures")}}
  <div class="ref-table-wrapper">
    <table class="ref-table structures-table">
      <thead>
        <tr>
          <th class="col-name">Structure</th>
          <th class="col-flag">STR</th>
          <th class="col-flag">Build</th>
          <th class="col-flag">Mat/Turn</th>
          <th class="col-flag">Capture</th>
          <th class="col-flag">Fortified</th>
          <th class="col-flag">Supply</th>
          <th class="col-flag">Comms</th>
          <th class="col-desc">Description</th>
        </tr>
      </thead>
      <tbody>
        {{#each structures}}
        <tr>
          <td class="col-name"><strong>{{label}}</strong></td>
          <td class="col-flag">{{strength}}</td>
          <td class="col-flag">{{buildTime}}</td>
          <td class="col-flag">{{matCost}}</td>
          <td class="col-flag">{{capturable}}</td>
          <td class="col-flag">{{fortified}}</td>
          <td class="col-flag">{{supplyRange}}</td>
          <td class="col-flag">{{commsRange}}</td>
          <td class="col-desc">{{description}}</td>
        </tr>
        {{/each}}
      </tbody>
    </table>
  </div>
  {{/if}}

</div>
