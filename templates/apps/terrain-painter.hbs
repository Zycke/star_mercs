<form class="star-mercs terrain-painter-form">
  <div class="form-group">
    <label>Terrain Type</label>
    <select name="selectedTerrain">
      {{selectOptions terrainChoices selected=selectedTerrain}}
    </select>
  </div>

  <div class="form-group">
    <label>Elevation (0–{{maxElevation}})</label>
    <input type="number" name="selectedElevation" value="{{selectedElevation}}"
           min="0" max="{{maxElevation}}" step="1"/>
  </div>

  <div class="form-group">
    <label class="checkbox">
      <input type="checkbox" name="selectedRoad" {{#if selectedRoad}}checked{{/if}}/>
      Road
    </label>
  </div>

  <div class="form-group">
    <label>Objective</label>
    <select name="selectedObjective">
      <option value="none" {{#if (eq selectedObjective "none")}}selected{{/if}}>None</option>
      <option value="primary" {{#if (eq selectedObjective "primary")}}selected{{/if}}>Primary (3 pts)</option>
      <option value="secondary" {{#if (eq selectedObjective "secondary")}}selected{{/if}}>Secondary (1 pt)</option>
    </select>
  </div>

  <div class="form-group">
    <label>Brush Size: {{brushSize}}</label>
    <input type="range" name="brushSize" value="{{brushSize}}" min="1" max="5" step="1"/>
  </div>

  <div class="form-group terrain-painter-buttons">
    <button type="button" class="toggle-painting {{#if isActive}}active{{/if}}">
      <i class="fas {{#if isActive}}fa-stop{{else}}fa-paint-brush{{/if}}"></i>
      {{#if isActive}}Stop Painting{{else}}Start Painting{{/if}}
    </button>
  </div>

  <div class="form-group">
    <button type="button" class="clear-all-terrain">
      <i class="fas fa-trash"></i> Clear All Terrain
    </button>
  </div>

  <p class="notes">
    <strong>Left-click/drag</strong> to paint terrain.<br/>
    <strong>Right-click/drag</strong> to erase terrain.
  </p>
</form>
