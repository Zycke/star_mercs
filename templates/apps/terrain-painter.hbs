<form class="star-mercs terrain-painter-form">
  {{#unless isStructureMode}}
  <div class="form-group">
    <label>Terrain Type</label>
    <select name="selectedTerrain">
      {{selectOptions terrainChoices selected=selectedTerrain}}
    </select>
  </div>

  <div class="terrain-elev-road-row">
    <div class="form-group">
      <label>Elevation</label>
      <input type="number" name="selectedElevation" value="{{selectedElevation}}"
             min="0" max="{{maxElevation}}" step="1"/>
    </div>
    <div class="form-group">
      <label class="checkbox">
        <input type="checkbox" name="selectedRoad" {{#if selectedRoad}}checked{{/if}}/>
        Road
      </label>
    </div>
  </div>

  <div class="terrain-obj-brush-row">
    <div class="form-group">
      <label>Objective</label>
      <select name="selectedObjective">
        <option value="none" {{#if (eq selectedObjective "none")}}selected{{/if}}>None</option>
        <option value="primary" {{#if (eq selectedObjective "primary")}}selected{{/if}}>Primary</option>
        <option value="secondary" {{#if (eq selectedObjective "secondary")}}selected{{/if}}>Secondary</option>
      </select>
    </div>
    <div class="form-group">
      <label>Brush: {{brushSize}}</label>
      <input type="range" name="brushSize" value="{{brushSize}}" min="1" max="5" step="1"/>
    </div>
  </div>
  {{/unless}}

  <hr/>
  <h4>Structure Placement</h4>

  <div class="form-group">
    <label>Structure</label>
    <select name="selectedStructure">
      <option value="" {{#unless selectedStructure}}selected{{/unless}}>-- Terrain Mode --</option>
      <option value="minefield" {{#if (eq selectedStructure "minefield")}}selected{{/if}}>Minefield</option>
      <option value="outpost" {{#if (eq selectedStructure "outpost")}}selected{{/if}}>Outpost</option>
      <option value="headquarters" {{#if (eq selectedStructure "headquarters")}}selected{{/if}}>Headquarters</option>
      <option value="fortification" {{#if (eq selectedStructure "fortification")}}selected{{/if}}>Fortification</option>
      <option value="removeStructure" {{#if (eq selectedStructure "removeStructure")}}selected{{/if}}>Remove Structure</option>
    </select>
  </div>

  {{#if isStructureMode}}
    {{#unless isRemoveStructureMode}}
    <div class="form-group">
      <label>Team</label>
      <select name="structureTeam">
        <option value="none" {{#if (eq structureTeam "none")}}selected{{/if}}>None (Neutral)</option>
        <option value="a" {{#if (eq structureTeam "a")}}selected{{/if}}>Team A (Blue)</option>
        <option value="b" {{#if (eq structureTeam "b")}}selected{{/if}}>Team B (Red)</option>
      </select>
    </div>
    {{/unless}}

    {{#if isMinefieldMode}}
    <div class="form-group">
      <label>Mine Type</label>
      <select name="mineSubType">
        <option value="antiPersonnel" {{#if (eq mineSubType "antiPersonnel")}}selected{{/if}}>Anti-Personnel</option>
        <option value="antiArmor" {{#if (eq mineSubType "antiArmor")}}selected{{/if}}>Anti-Armor</option>
      </select>
    </div>
    {{/if}}
  {{/if}}

  <div class="form-group terrain-painter-buttons">
    <button type="button" class="toggle-painting {{#if isActive}}active{{/if}}">
      <i class="fas {{#if isActive}}fa-stop{{else}}fa-paint-brush{{/if}}"></i>
      {{#if isActive}}Stop Painting{{else}}Start Painting{{/if}}
    </button>
  </div>

  <div class="form-group">
    <button type="button" class="clear-all-terrain">
      <i class="fas fa-trash"></i> Clear All Terrain
    </button>
  </div>

  <p class="notes">
    {{#if isStructureMode}}
    <strong>Left-click</strong> to place/remove structures.<br/>
    <strong>Right-click/drag</strong> to erase terrain.
    {{else}}
    <strong>Left-click/drag</strong> to paint terrain.<br/>
    <strong>Right-click/drag</strong> to erase terrain.
    {{/if}}
  </p>
</form>
