<div class="star-mercs structure-settings-form">
  <p class="notes">Configure default values for constructable structure types. Changes apply to newly built structures.</p>

  {{#each types}}
  <fieldset class="structure-type-section" data-type="{{key}}">
    <legend><i class="{{icon}}"></i> {{label}}</legend>

    <div class="structure-stats-row">
      <div class="form-group">
        <label>Strength</label>
        <input type="number" name="{{key}}.maxStrength" value="{{maxStrength}}" min="1" step="1"/>
      </div>
      <div class="form-group">
        <label>Turns</label>
        <input type="number" name="{{key}}.turnsRequired" value="{{turnsRequired}}" min="1" step="1"/>
      </div>
      <div class="form-group">
        <label>Mat/Turn</label>
        <input type="number" name="{{key}}.materialsPerTurn" value="{{materialsPerTurn}}" min="0" step="1"/>
      </div>
    </div>

    {{#if hasSupply}}
    <div class="structure-stats-row">
      <div class="form-group">
        <label>Comms Range</label>
        <input type="number" name="{{key}}.commsRange" value="{{commsRange}}" min="0" step="1"/>
      </div>
      <div class="form-group">
        <label>Supply Range</label>
        <input type="number" name="{{key}}.supplyRange" value="{{supplyRange}}" min="0" step="1"/>
      </div>
      {{#if isHeadquarters}}
      <div class="form-group">
        <label>Deploy Radius</label>
        <input type="number" name="{{key}}.deployRadius" value="{{deployRadius}}" min="1" step="1"/>
      </div>
      {{/if}}
    </div>
    <details class="supply-capacities">
      <summary>Supply Capacities</summary>
      <div class="supply-grid">
        <div class="form-group"><label>Proj</label><input type="number" name="{{key}}.supply.projectile" value="{{supplyProjectile}}" min="0"/></div>
        <div class="form-group"><label>Ord</label><input type="number" name="{{key}}.supply.ordnance" value="{{supplyOrdnance}}" min="0"/></div>
        <div class="form-group"><label>Energy</label><input type="number" name="{{key}}.supply.energy" value="{{supplyEnergy}}" min="0"/></div>
        <div class="form-group"><label>Fuel</label><input type="number" name="{{key}}.supply.fuel" value="{{supplyFuel}}" min="0"/></div>
        <div class="form-group"><label>Mats</label><input type="number" name="{{key}}.supply.materials" value="{{supplyMaterials}}" min="0"/></div>
        <div class="form-group"><label>Parts</label><input type="number" name="{{key}}.supply.parts" value="{{supplyParts}}" min="0"/></div>
        <div class="form-group"><label>Basic</label><input type="number" name="{{key}}.supply.basicSupplies" value="{{supplyBasicSupplies}}" min="0"/></div>
      </div>
    </details>
    {{/if}}
  </fieldset>
  {{/each}}

  <div class="form-group structure-settings-buttons">
    <button type="button" class="save-settings">
      <i class="fas fa-save"></i> Save
    </button>
    <button type="button" class="reset-defaults">
      <i class="fas fa-undo"></i> Reset
    </button>
  </div>
</div>
