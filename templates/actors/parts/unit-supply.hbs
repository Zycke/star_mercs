<div class="supply-section">
  <h3>Supply</h3>

  {{!-- Ammunition Categories --}}
  <div class="supply-categories-grid ammo-row">
    <div class="supply-category">
      <div class="supply-category-header">
        <i class="fas fa-crosshairs"></i>
        <span>Projectile Ammo</span>
      </div>
      <div class="resource-bar">
        <input type="number" name="system.supply.projectile.current"
               value="{{system.supply.projectile.current}}" min="0" max="{{system.supply.projectile.capacity}}"/>
        <span class="sep">/</span>
        <input type="number" name="system.supply.projectile.capacity"
               value="{{system.supply.projectile.capacity}}" min="0"/>
      </div>
    </div>

    <div class="supply-category">
      <div class="supply-category-header">
        <i class="fas fa-rocket"></i>
        <span>Ordnance</span>
      </div>
      <div class="resource-bar">
        <input type="number" name="system.supply.ordnance.current"
               value="{{system.supply.ordnance.current}}" min="0" max="{{system.supply.ordnance.capacity}}"/>
        <span class="sep">/</span>
        <input type="number" name="system.supply.ordnance.capacity"
               value="{{system.supply.ordnance.capacity}}" min="0"/>
      </div>
    </div>

    <div class="supply-category">
      <div class="supply-category-header">
        <i class="fas fa-bolt"></i>
        <span>Energy</span>
      </div>
      <div class="resource-bar">
        <input type="number" name="system.supply.energy.current"
               value="{{system.supply.energy.current}}" min="0" max="{{system.supply.energy.capacity}}"/>
        <span class="sep">/</span>
        <input type="number" name="system.supply.energy.capacity"
               value="{{system.supply.energy.capacity}}" min="0"/>
      </div>
      <div class="fuel-per-hex">
        <label>Recharge:</label>
        <input type="number" name="system.supply.energy.rechargeRate"
               value="{{system.supply.energy.rechargeRate}}" min="0"/>
        <span class="suffix">/turn</span>
      </div>
    </div>
  </div>

  {{!-- Fuel and Basic Supplies --}}
  <div class="supply-categories-grid logistics-row">
    <div class="supply-category">
      <div class="supply-category-header">
        <i class="fas fa-gas-pump"></i>
        <span>Fuel</span>
      </div>
      <div class="resource-bar">
        <input type="number" name="system.supply.fuel.current"
               value="{{system.supply.fuel.current}}" min="0" max="{{system.supply.fuel.capacity}}"/>
        <span class="sep">/</span>
        <input type="number" name="system.supply.fuel.capacity"
               value="{{system.supply.fuel.capacity}}" min="0"/>
      </div>
      <div class="fuel-per-hex">
        <label>Per MP:</label>
        <input type="number" name="system.fuelPerMP"
               value="{{system.fuelPerMP}}" min="0"/>
      </div>
    </div>

    <div class="supply-category">
      <div class="supply-category-header">
        <i class="fas fa-medkit"></i>
        <span>Basic Supplies</span>
      </div>
      <div class="resource-bar">
        <input type="number" name="system.supply.basicSupplies.current"
               value="{{system.supply.basicSupplies.current}}" min="0" max="{{system.supply.basicSupplies.capacity}}"/>
        <span class="sep">/</span>
        <input type="number" name="system.supply.basicSupplies.capacity"
               value="{{system.supply.basicSupplies.capacity}}" min="0"/>
      </div>
    </div>
  </div>

  {{!-- Placeholder Categories (Materials & Parts) --}}
  <div class="supply-categories-grid placeholder-row">
    <div class="supply-category placeholder">
      <div class="supply-category-header">
        <i class="fas fa-hammer"></i>
        <span>Materials</span>
      </div>
      <div class="resource-bar">
        <input type="number" name="system.supply.materials.current"
               value="{{system.supply.materials.current}}" min="0" max="{{system.supply.materials.capacity}}"/>
        <span class="sep">/</span>
        <input type="number" name="system.supply.materials.capacity"
               value="{{system.supply.materials.capacity}}" min="0"/>
      </div>
      <div class="placeholder-note">
        <i class="fas fa-info-circle"></i> Not yet implemented
      </div>
    </div>

    <div class="supply-category placeholder">
      <div class="supply-category-header">
        <i class="fas fa-wrench"></i>
        <span>Parts</span>
      </div>
      <div class="resource-bar">
        <input type="number" name="system.supply.parts.current"
               value="{{system.supply.parts.current}}" min="0" max="{{system.supply.parts.capacity}}"/>
        <span class="sep">/</span>
        <input type="number" name="system.supply.parts.capacity"
               value="{{system.supply.parts.capacity}}" min="0"/>
      </div>
      <div class="placeholder-note">
        <i class="fas fa-info-circle"></i> Not yet implemented
      </div>
    </div>
  </div>

  {{!-- Supply Transfer (only during preparation phase) --}}
  {{#if canTransferSupply}}
    <div class="supply-transfer-section">
      <button type="button" class="transfer-supply-btn">
        <i class="fas fa-truck"></i> Transfer Supply
        <span class="transfer-range-info">({{supplyTransferRange}} hex range)</span>
      </button>
    </div>
  {{else}}
    <div class="supply-transfer-section">
      <span class="transfer-disabled-note">
        <i class="fas fa-clock"></i> Supply transfers are only allowed during the Preparation phase.
      </span>
    </div>
  {{/if}}

  {{#if hasNoSupply}}
    <div class="supply-warning">
      <i class="fas fa-exclamation-triangle"></i>
      No ammo supply — only Hold, Move, and Withdraw orders are available.
    </div>
  {{/if}}

  <div class="notes-section">
    <h3>Notes</h3>
    <textarea name="system.notes" rows="6" placeholder="Unit notes...">{{system.notes}}</textarea>
  </div>
</div>
